<?xml version="1.0" encoding="utf-8"?>

<configuration>

	<connectionStrings>

		<add name="ExamDbConnection"
			 connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=OnlineExamDB;Integrated Security=True"
			 providerName="System.Data.SqlClient"/>

	</connectionStrings>

	<system.web>

		<compilation debug="true" targetFramework="4.6" />

		<httpRuntime targetFramework="4.6" />

		<sessionState timeout="60" />

		<customErrors mode="Off" />

	</system.web>

	<system.net>

		<mailSettings>

			<smtp from="yourgmail@gmail.com">

				<network
					host="smtp.gmail.com"
					port="587"
					userName=""
					password=""
					enableSsl="true" />
			</smtp>

		</mailSettings>

	</system.net>

</configuration>